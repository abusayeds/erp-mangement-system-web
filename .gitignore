# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Laravel source reference (local junction, not part of this repo)
/laravel

# Node.js backend reference (local junction, not part of this repo)
/backend

# Local editor / agent config (never push)
.cursor/
AGENTS.md
CLAUDE.md
